# ==================================================
# BUNNY STREAM - Configurações
# ==================================================

# ID da sua biblioteca no Bunny Stream
# Encontre em: https://dash.bunny.net/stream
BUNNY_LIBRARY_ID=607508

# Chave de segurança para tokens
# Encontre em: Bunny Dashboard > Stream > Security
BUNNY_TOKEN_KEY=34dd21bd-82dd-41be-a6d1902e8f55-3d1a-43d4

# ==================================================
# MAPEAMENTO DE VÍDEOS
# ==================================================
# Cada vídeo do seu sistema precisa ter um ID correspondente no Bunny
# Formato: BUNNY_VIDEO_[ID_DO_VIDEO_EM_MAIUSCULO]

# Exemplo:
BUNNY_VIDEO_VIDEO-1=0bd9c107-e76c-45d3-a06f-a3cc82788978
BUNNY_VIDEO_VIDEO-2=def456-bunny-video-id
BUNNY_VIDEO_VIDEO-3=ghi789-bunny-video-id

# ... adicione todos os seus vídeos aqui

# ==================================================
# COMO OBTER OS IDS DOS VÍDEOS NO BUNNY:
# ==================================================
# 1. Faça upload do vídeo no Bunny Stream
# 2. Vá em: https://dash.bunny.net/stream
# 3. Clique no vídeo
# 4. Copie o "Video ID" (GUID)
# 5. Cole aqui no formato: BUNNY_VIDEO_[SEU_ID]=guid-do-bunny

# ==================================================
# AUTENTICAÇÃO (OPCIONAL)
# ==================================================
# Se você usar NextAuth ou outro sistema de autenticação

# NEXTAUTH_SECRET=your-secret-key
# NEXTAUTH_URL=http://localhost:3000

# ==================================================
# BANCO DE DADOS (OPCIONAL)
# ==================================================
# Se você quiser salvar progresso e atividades

# DATABASE_URL=postgresql://user:password@localhost:5432/dbname
